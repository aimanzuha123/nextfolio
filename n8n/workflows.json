{
  "name": "Nextfolio Portfolio Generation Workflow",
  "description": "Production-grade n8n workflow for AI portfolio generation pipeline",
  "version": "1.0.0",
  "nodes": [
    {
      "id": "webhook-trigger",
      "name": "Portfolio Generation Webhook",
      "type": "n8n-nodes-base.webhook",
      "position": [100, 300],
      "parameters": {
        "httpMethod": "POST",
        "path": "generate-portfolio",
        "authentication": "headerAuth",
        "responseMode": "responseNode",
        "options": {
          "rawBody": true
        }
      }
    }
  ],
  "connections": {}
}
